# SwitchBot CO2 センサーの MAC アドレス（SwitchBot アプリまたは hcitool で確認）
SWITCHBOT_MAC=AA:BB:CC:DD:EE:FF

# MyRoom API（本番 URL は環境に合わせて変更）
# 動作確認: curl -X POST "$MYROOM_API_URL?device=$MYROOM_DEVICE_ID" ...
MYROOM_API_URL=https://myroom.gucchii.com/api/sensor
MYROOM_DEVICE_ID=2

# --- 白くまくんアプリ (AirCloud Home) エアコン連携 ---
# 白くまくんアプリに登録したメールアドレスとパスワード
AIRCON_EMAIL=your@email.com
AIRCON_PASSWORD=your_password
# 複数台ある場合は名前または ID を指定（省略時は1台のみなら自動選択）
# AIRCON_UNIT_NAME=リビング
# AIRCON_UNIT_ID=12345
MYROOM_AIRCON_API_URL=https://myroom.gucchii.com/api/aircon

# BLE スキャン待ち時間（秒）。センサーは約5分間隔でアドバタイズするため 90 推奨
SCAN_TIMEOUT=90
HTTP_TIMEOUT=30
